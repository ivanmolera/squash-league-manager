{
  "name": "squash-league-manager",
  "version": "0.1.5",
  "private": true,
  "description": "Web app for managing squash leagues, teams, tournaments, rankings and historical results.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "db:migrate": "flyway -configFiles=flyway.conf migrate",
    "db:info": "flyway -configFiles=flyway.conf info",
    "db:validate": "flyway -configFiles=flyway.conf validate",
    "geocode:clubs": "node scripts/geocode-clubs.mjs",
    "import:lineups": "node scripts/import-lineups-csv.mjs",
    "import:individual-league": "node scripts/import-individual-league-csv.mjs",
    "import:team-league": "node scripts/import-team-league-csv.mjs",
    "import:tournaments": "node scripts/import-tournaments-csv.mjs",
    "import:ct-sabadell-2026": "node scripts/import-ct-sabadell-2026-csv.mjs",
    "demo:ranking-tournament-results": "node scripts/create-demo-ranking-tournament-results.mjs",
    "recalculate:player-skills": "node scripts/recalculate-player-skills.mjs",
    "seed:admin": "node scripts/seed-admin.mjs",
    "seed:demo": "node scripts/seed-demo.mjs"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "firebase": "^11.0.2",
    "firebase-admin": "^12.7.0",
    "lucide-react": "^0.468.0",
    "next": "^15.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.14.0",
    "eslint-config-next": "^15.0.3",
    "prisma": "^5.22.0",
    "typescript": "^5.6.3"
  }
}
