generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  manager
  player

  @@map("user_role")
}

enum SeasonStatus {
  draft
  active
  closed

  @@map("season_status")
}

enum Gender {
  male
  female
  other
  not_specified

  @@map("gender")
}

enum DominantHand {
  right
  left
  ambidextrous
  not_specified

  @@map("dominant_hand")
}

enum CompetitionType {
  individual_league
  team_league
  tournament

  @@map("competition_type")
}

enum CompetitionStatus {
  draft
  registration_open
  active
  closed
  cancelled

  @@map("competition_status")
}

enum RankingScope {
  none
  autonomic
  state
  psa

  @@map("ranking_scope")
}

enum CompetitionFormat {
  league
  knockout
  round_robin

  @@map("competition_format")
}

enum MatchType {
  individual_league
  team_rubber
  tournament_knockout
  tournament_round_robin
  tournament_consolation
  tournament_third_place

  @@map("match_type")
}

enum MatchStatus {
  scheduled
  played
  walkover
  bye
  cancelled
  retired

  @@map("match_status")
}

enum RegistrationStatus {
  pending
  accepted
  rejected
  withdrawn

  @@map("registration_status")
}

enum JoinRequestStatus {
  pending
  approved
  rejected
  cancelled

  @@map("join_request_status")
}

enum CourtReservationStatus {
  active
  cancelled

  @@map("court_reservation_status")
}

enum PlayerLinkRequestStatus {
  pending
  approved
  rejected

  @@map("player_link_request_status")
}

model User {
  id          String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firebaseUid String               @unique @map("firebase_uid")
  email       String               @unique
  emailVerified Boolean            @default(false) @map("email_verified")
  suspendedAt DateTime?            @map("suspended_at") @db.Timestamptz(6)
  suspendedByUserId String?        @map("suspended_by_user_id") @db.Uuid
  suspensionReason String?         @map("suspension_reason")
  phone       String?
  preferredLocale String           @default("es") @map("preferred_locale")
  displayName String?              @map("display_name")
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime             @default(now()) @map("updated_at") @db.Timestamptz(6)
  player      Player?
  roles       UserRoleAssignment[]
  managedClub Club?
  credential  AuthCredential?
  sessions    AuthSession[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]
  playerLinkRequests PlayerLinkRequest[] @relation("PlayerLinkRequestUser")
  reviewedPlayerLinkRequests PlayerLinkRequest[] @relation("PlayerLinkRequestReviewer")
  playerMergeLogs PlayerMergeLog[] @relation("PlayerMergeActor")
  courtReservations CourtReservation[] @relation("CourtReservationUser")
  cancelledCourtReservations CourtReservation[] @relation("CourtReservationCancelledBy")
  createdFeatureSettings AppFeatureSetting[]
  suspendedBy User?                 @relation("UserSuspensions", fields: [suspendedByUserId], references: [id], onDelete: SetNull)
  suspendedUsers User[]             @relation("UserSuspensions")

  @@map("app_users")
}

model AuthCredential {
  userId            String   @id @map("user_id") @db.Uuid
  passwordHash      String   @map("password_hash")
  passwordChangedAt DateTime @default(now()) @map("password_changed_at") @db.Timestamptz(6)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_credentials")
}

model AuthSession {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model EmailVerificationToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model UserRoleAssignment {
  userId    String   @map("user_id") @db.Uuid
  role      UserRole
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, role])
  @@map("app_user_roles")
}

model Player {
  id                    String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String?                   @unique @map("user_id") @db.Uuid
  firstName             String                    @map("first_name")
  lastName              String                    @map("last_name")
  gender                Gender                    @default(not_specified)
  birthDate             DateTime?                 @map("birth_date") @db.Date
  heightCm              Int?                      @map("height_cm")
  weightKg              Decimal?                  @map("weight_kg") @db.Decimal(5, 2)
  dominantHand          DominantHand              @default(not_specified) @map("dominant_hand")
  racketBrand           String?                   @map("racket_brand")
  profilePhotoUrl       String?                   @map("profile_photo_url")
  genericProfileVariant String                    @default("neutral") @map("generic_profile_variant")
  showContactPublic     Boolean                   @default(true) @map("show_contact_public")
  showPhysicalPublic    Boolean                   @default(true) @map("show_physical_public")
  receivesMatchCommunications Boolean             @default(false) @map("receives_match_communications")
  mergedIntoPlayerId String?                      @map("merged_into_player_id") @db.Uuid
  mergedAt             DateTime?                  @map("merged_at") @db.Timestamptz(6)
  createdAt             DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime                  @default(now()) @map("updated_at") @db.Timestamptz(6)
  user                  User?                     @relation(fields: [userId], references: [id], onDelete: SetNull)
  mergedInto            Player?                   @relation("PlayerProfileMerges", fields: [mergedIntoPlayerId], references: [id], onDelete: SetNull)
  mergedPlayers         Player[]                  @relation("PlayerProfileMerges")
  linkRequests          PlayerLinkRequest[]       @relation("PlayerLinkRequestCandidate")
  primaryMergeLogs      PlayerMergeLog[]          @relation("PlayerMergePrimary")
  duplicateMergeLogs    PlayerMergeLog[]          @relation("PlayerMergeDuplicate")
  memberships           PlayerClubMembership[]
  rosters               TeamRoster[]
  registrations         TournamentRegistration[]
  joinRequests          ClubJoinRequest[]
  competitionParticipants CompetitionParticipant[]
  courtReservations CourtReservation[] @relation("CourtReservationPlayer")
  partnerCourtReservations CourtReservation[] @relation("CourtReservationPartner")
  rankingCategories PlayerRankingCategory[]

  @@map("players")
}

model PlayerLinkRequest {
  id                  String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String                  @map("user_id") @db.Uuid
  candidatePlayerId   String                  @map("candidate_player_id") @db.Uuid
  requestedFirstName  String                  @map("requested_first_name")
  requestedLastName   String                  @map("requested_last_name")
  requestedEmail      String                  @map("requested_email")
  matchScore          Int                     @default(0) @map("match_score")
  matchReasons        Json?                   @map("match_reasons")
  status              PlayerLinkRequestStatus @default(pending)
  reviewedByUserId    String?                 @map("reviewed_by_user_id") @db.Uuid
  reviewedAt          DateTime?               @map("reviewed_at") @db.Timestamptz(6)
  createdAt           DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime                @default(now()) @map("updated_at") @db.Timestamptz(6)
  user                User                    @relation("PlayerLinkRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  candidatePlayer     Player                  @relation("PlayerLinkRequestCandidate", fields: [candidatePlayerId], references: [id], onDelete: Cascade)
  reviewedBy          User?                   @relation("PlayerLinkRequestReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@unique([userId, candidatePlayerId, status])
  @@map("player_link_requests")
}

model PlayerMergeLog {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  primaryPlayerId   String   @map("primary_player_id") @db.Uuid
  duplicatePlayerId String   @map("duplicate_player_id") @db.Uuid
  mergedByUserId    String?  @map("merged_by_user_id") @db.Uuid
  beforeData        Json?    @map("before_data")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  primaryPlayer     Player   @relation("PlayerMergePrimary", fields: [primaryPlayerId], references: [id], onDelete: Cascade)
  duplicatePlayer   Player   @relation("PlayerMergeDuplicate", fields: [duplicatePlayerId], references: [id], onDelete: Cascade)
  mergedBy          User?    @relation("PlayerMergeActor", fields: [mergedByUserId], references: [id], onDelete: SetNull)

  @@unique([duplicatePlayerId])
  @@map("player_merge_logs")
}

model Club {
  id            String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String                 @unique
  city          String?
  province      String?
  address       String?
  postalCode    String?                @map("postal_code") @db.VarChar(16)
  latitude      Float?
  longitude     Float?
  geocodedAt    DateTime?              @map("geocoded_at") @db.Timestamptz(6)
  geocodingQuery String?               @map("geocoding_query")
  availableCourts Int                   @default(0) @map("available_courts")
  phone         String?
  managesCourtBookings Boolean          @default(false) @map("manages_court_bookings")
  websiteUrl    String?                @map("website_url")
  logoUrl       String?                @map("logo_url")
  showContactPublic Boolean            @default(true) @map("show_contact_public")
  managerUserId String?                @unique @map("manager_user_id") @db.Uuid
  createdAt     DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime               @default(now()) @map("updated_at") @db.Timestamptz(6)
  manager       User?                  @relation(fields: [managerUserId], references: [id], onDelete: SetNull)
  teams         Team[]
  memberships   PlayerClubMembership[]
  joinRequests  ClubJoinRequest[]
  competitionParticipants CompetitionParticipant[]
  hostedCompetitions Competition[]
  courtReservations CourtReservation[]
  closedDays CourtClosedDay[]

  @@map("clubs")
}

model AppFeatureSetting {
  featureKey      String   @id @map("feature_key")
  enabled         Boolean  @default(true)
  updatedByUserId String?  @map("updated_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  updatedBy       User?    @relation(fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@map("app_feature_settings")
}

model Ranking {
  id          String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String                  @unique @db.VarChar(8)
  name        String
  scope       RankingScope            @default(none)
  logoUrl     String?                 @map("logo_url")
  active      Boolean                 @default(true)
  sortOrder   Int                     @default(0) @map("sort_order")
  createdAt   DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime                @default(now()) @map("updated_at") @db.Timestamptz(6)
  categories  RankingCategory[]
  playerCategories PlayerRankingCategory[]
  competitions Competition[]
  teams       Team[]

  @@map("rankings")
}

model CourtReservation {
  id                String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId            String                 @map("club_id") @db.Uuid
  courtNumber       Int                    @map("court_number")
  userId            String                 @map("user_id") @db.Uuid
  playerId          String?                @map("player_id") @db.Uuid
  partnerPlayerId   String?                @map("partner_player_id") @db.Uuid
  startsAt          DateTime               @map("starts_at") @db.Timestamptz(6)
  endsAt            DateTime               @map("ends_at") @db.Timestamptz(6)
  status            CourtReservationStatus @default(active)
  cancelledAt       DateTime?              @map("cancelled_at") @db.Timestamptz(6)
  cancelledByUserId String?                @map("cancelled_by_user_id") @db.Uuid
  createdAt         DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime               @default(now()) @map("updated_at") @db.Timestamptz(6)
  createdByUserId   String?                @map("created_by_user_id") @db.Uuid
  updatedByUserId   String?                @map("updated_by_user_id") @db.Uuid
  club              Club                   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user              User                   @relation("CourtReservationUser", fields: [userId], references: [id], onDelete: Cascade)
  player            Player?                @relation("CourtReservationPlayer", fields: [playerId], references: [id], onDelete: SetNull)
  partnerPlayer     Player?                @relation("CourtReservationPartner", fields: [partnerPlayerId], references: [id], onDelete: SetNull)
  cancelledBy       User?                  @relation("CourtReservationCancelledBy", fields: [cancelledByUserId], references: [id], onDelete: SetNull)

  @@map("court_reservations")
}

model CourtClosedDay {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId          String   @map("club_id") @db.Uuid
  closedOn        DateTime @map("closed_on") @db.Date
  reason          String?
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  createdByUserId String?  @map("created_by_user_id") @db.Uuid
  updatedByUserId String?  @map("updated_by_user_id") @db.Uuid
  club            Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, closedOn])
  @@map("club_closed_days")
}

model Season {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String       @unique
  startsAt  DateTime     @map("starts_at") @db.Date
  endsAt    DateTime     @map("ends_at") @db.Date
  status    SeasonStatus @default(draft)
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)
  memberships PlayerClubMembership[]
  competitions Competition[]
  leagueMatchdays LeagueMatchday[]
  joinRequests ClubJoinRequest[]
  playerRankingCategories PlayerRankingCategory[]

  @@map("seasons")
}

model Category {
  id          String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  genderScope Gender                @default(not_specified) @map("gender_scope")
  minAge      Int?                  @map("min_age")
  maxAge      Int?                  @map("max_age")
  sortOrder   Int                   @default(0) @map("sort_order")
  createdAt   DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  competitions CompetitionCategory[]
  rankings    RankingCategory[]
  playerRankingCategories PlayerRankingCategory[]

  @@unique([name, genderScope, minAge, maxAge])
  @@map("categories")
}

model RankingCategory {
  rankingId       String   @map("ranking_id") @db.Uuid
  categoryId      String   @map("category_id") @db.Uuid
  isLevelCategory Boolean  @default(false) @map("is_level_category")
  levelOrder      Int?     @map("level_order")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  ranking         Ranking  @relation(fields: [rankingId], references: [id], onDelete: Cascade)
  category        Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([rankingId, categoryId])
  @@map("ranking_categories")
}

model PlayerRankingCategory {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  playerId        String    @map("player_id") @db.Uuid
  rankingId       String    @map("ranking_id") @db.Uuid
  seasonId        String    @map("season_id") @db.Uuid
  categoryId      String    @map("category_id") @db.Uuid
  isLevelCategory Boolean   @default(false) @map("is_level_category")
  levelOrder      Int?      @map("level_order")
  validFrom       DateTime  @default(now()) @map("valid_from") @db.Date
  validTo         DateTime? @map("valid_to") @db.Date
  source          String    @default("manual") @db.VarChar(32)
  notes           String?
  createdByUserId String?   @map("created_by_user_id") @db.Uuid
  updatedByUserId String?   @map("updated_by_user_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  player          Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  ranking         Ranking   @relation(fields: [rankingId], references: [id], onDelete: Cascade)
  season          Season    @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  category        Category  @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@unique([playerId, rankingId, seasonId, categoryId, validFrom])
  @@map("player_ranking_categories")
}

model Competition {
  id          String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  seasonId    String                 @map("season_id") @db.Uuid
  type        CompetitionType
  status      CompetitionStatus      @default(draft)
  name        String
  description String?
  posterUrl   String?                @map("poster_url")
  bestOfSets  Int                    @default(5) @map("best_of_sets")
  refereeName String?                @map("referee_name")
  rankingScope RankingScope          @default(none) @map("ranking_scope")
  rankingCode  String                @default("none") @map("ranking_code") @db.VarChar(8)
  rankingId    String?               @map("ranking_id") @db.Uuid
  registrationDeadline DateTime?        @map("registration_deadline") @db.Timestamptz(6)
  startsAt    DateTime?              @map("starts_at") @db.Timestamptz(6)
  endsAt      DateTime?              @map("ends_at") @db.Timestamptz(6)
  matchFrequency String               @default("biweekly") @map("match_frequency") @db.VarChar(16)
  preferredMatchWeekday Int?          @map("preferred_match_weekday")
  hostClubId  String?                @map("host_club_id") @db.Uuid
  createdAt   DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime               @default(now()) @map("updated_at") @db.Timestamptz(6)
  season      Season                 @relation(fields: [seasonId], references: [id], onDelete: Restrict)
  hostClub    Club?                  @relation(fields: [hostClubId], references: [id], onDelete: SetNull)
  ranking     Ranking?               @relation(fields: [rankingId], references: [id], onDelete: SetNull)
  categories  CompetitionCategory[]
  participants CompetitionParticipant[]
  matches      Match[]
  leagueMatchdays LeagueMatchday[]

  @@map("competitions")
}

model CompetitionCategory {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  competitionId String            @map("competition_id") @db.Uuid
  categoryId    String            @map("category_id") @db.Uuid
  displayName   String            @map("display_name")
  format        CompetitionFormat
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  competition   Competition       @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  category      Category          @relation(fields: [categoryId], references: [id])
  participants  CompetitionParticipant[]
  registrations TournamentRegistration[]
  seeds         TournamentSeed[]
  drawEntries   TournamentDrawEntry[]
  leagueMatchdays LeagueMatchday[]

  @@unique([competitionId, displayName])
  @@map("competition_categories")
}

model LeagueMatchday {
  id                    String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  seasonId              String              @map("season_id") @db.Uuid
  competitionId          String              @map("competition_id") @db.Uuid
  competitionCategoryId  String              @map("competition_category_id") @db.Uuid
  roundNumber            Int                 @map("round_number")
  startsAt               DateTime            @map("starts_at") @db.Date
  endsAt                 DateTime            @map("ends_at") @db.Date
  createdAt              DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime            @default(now()) @map("updated_at") @db.Timestamptz(6)
  season                 Season              @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  competition            Competition         @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  competitionCategory    CompetitionCategory @relation(fields: [competitionCategoryId], references: [id], onDelete: Cascade)
  matches                Match[]
  teamTies               TeamTie[]

  @@unique([competitionCategoryId, roundNumber])
  @@map("league_matchdays")
}

model CompetitionParticipant {
  id                    String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  competitionId          String              @map("competition_id") @db.Uuid
  competitionCategoryId  String              @map("competition_category_id") @db.Uuid
  playerId              String?             @map("player_id") @db.Uuid
  clubId                String?             @map("club_id") @db.Uuid
  seedNumber            Int?                @map("seed_number")
  createdByUserId       String?             @map("created_by_user_id") @db.Uuid
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  competition           Competition         @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  competitionCategory    CompetitionCategory @relation(fields: [competitionCategoryId], references: [id], onDelete: Cascade)
  player                Player?             @relation(fields: [playerId], references: [id], onDelete: Cascade)
  club                  Club?               @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([competitionCategoryId, playerId])
  @@unique([competitionCategoryId, clubId])
  @@unique([competitionCategoryId, seedNumber])
  @@map("competition_participants")
}

model PlayerClubMembership {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  playerId  String    @map("player_id") @db.Uuid
  clubId    String    @map("club_id") @db.Uuid
  seasonId  String    @map("season_id") @db.Uuid
  clubNameAtThatTime String @map("club_name_at_that_time")
  fromDate  DateTime  @map("from_date") @db.Date
  toDate    DateTime? @map("to_date") @db.Date
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  player    Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  club      Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  season    Season    @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([playerId, clubId, seasonId])
  @@unique([playerId, seasonId])
  @@map("player_club_memberships")
}

model Team {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId     String       @map("club_id") @db.Uuid
  seasonId   String       @map("season_id") @db.Uuid
  categoryId String       @map("category_id") @db.Uuid
  rankingId  String?      @map("ranking_id") @db.Uuid
  name       String
  clubNameAtCreation String @map("club_name_at_creation")
