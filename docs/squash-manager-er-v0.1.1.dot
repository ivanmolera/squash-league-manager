digraph ERD {
  graph [rankdir=LR, bgcolor="white", pad="0.25", nodesep="0.55", ranksep="0.9"];
  node [shape=plain, fontname="Arial"];
  edge [fontname="Arial", fontsize=9, color="#52616b", arrowsize=0.7];
